<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZOMIUM | Develop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-white">
    <%- include("partials/navbar") %>
    <% const pageError = typeof error !== "undefined" ? error : null; %>
    <% const pageSuccess = typeof success !== "undefined" ? success : null; %>
    <% const pageFormData = typeof formData !== "undefined" ? formData : {}; %>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card bg-black border border-secondary text-white shadow-lg">
                    <div class="card-body p-4 p-md-5">
                        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                            <div>
                                <h2 class="mb-1 fw-bold">Develop</h2>
                                <p class="text-secondary mb-0">Create a new game and publish it to the games page.</p>
                            </div>

                            <button
                                class="btn btn-primary"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#createGameForm"
                                aria-expanded="<%= pageError ? 'true' : 'false' %>"
                                aria-controls="createGameForm"
                            >
                                Create Game
                            </button>
                        </div>

                        <% if (pageError) { %>
                            <div class="alert alert-danger" role="alert">
                                <%= pageError %>
                            </div>
                        <% } %>

                        <% if (pageSuccess) { %>
                            <div class="alert alert-success" role="alert">
                                <%= pageSuccess %>
                            </div>
                        <% } %>

                        <div class="collapse <%= pageError ? 'show' : '' %>" id="createGameForm">
                            <div class="card card-body bg-dark border border-secondary">
                                <form action="/develop/create-game" method="post" novalidate>
                                    <div class="mb-3">
                                        <label for="name" class="form-label">Game Name</label>
                                        <input
                                            id="name"
                                            name="name"
                                            type="text"
                                            class="form-control"
                                            maxlength="100"
                                            value="<%= pageFormData.name || '' %>"
                                            required
                                        >
                                    </div>

                                    <div class="mb-4">
                                        <label for="description" class="form-label">Description</label>
                                        <textarea
                                            id="description"
                                            name="description"
                                            class="form-control"
                                            rows="5"
                                            required
                                        ><%= pageFormData.description || '' %></textarea>
                                    </div>

                                    <button type="submit" class="btn btn-primary">
                                        Create Game
                                    </button>
                                </form>
                            </div>
                        </div>

                        <div class="mt-4 pt-4 border-top border-secondary">
                            <h5 class="fw-semibold">How it works</h5>
                            <p class="text-secondary mb-0">
                                Fill in the game name and description, submit the form, and the new game will appear on the games page as its own card.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include("partials/footer") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
