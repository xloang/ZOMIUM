<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZOMIUM | Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-white">
    <%- include("partials/navbar") %>
    <% const pageError = typeof error !== "undefined" ? error : null; %>
    <% const pageFormData = typeof formData !== "undefined" ? formData : {}; %>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card bg-black border border-secondary text-white shadow-lg">
                    <div class="card-body p-4 p-md-5">
                        <h2 class="mb-4 fw-bold">Login</h2>

                        <% if (pageError) { %>
                            <div class="alert alert-danger" role="alert">
                                <%= pageError %>
                            </div>
                        <% } %>

                        <form action="/login" method="post" novalidate>
                            <div class="mb-3">
                                <label for="username" class="form-label">Username</label>
                                <input
                                    id="username"
                                    name="username"
                                    type="text"
                                    class="form-control"
                                    value="<%= pageFormData.username || '' %>"
                                    autocomplete="username"
                                    required
                                >
                            </div>

                            <div class="mb-4">
                                <label for="password" class="form-label">Password</label>
                                <input
                                    id="password"
                                    name="password"
                                    type="password"
                                    class="form-control"
                                    autocomplete="current-password"
                                    required
                                >
                            </div>

                            <button type="submit" class="btn btn-primary w-100">Login</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include("partials/footer") %>

     <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
 </body>
 </html>
