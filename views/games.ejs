<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZOMIUM | Games</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-white">
<%- include("partials/navbar") %>
<% const viewer = typeof currentUser !== "undefined" ? currentUser : null; %>
<% const pageGames = Array.isArray(games) ? games : []; %>
<% const pageError = typeof error !== "undefined" ? error : null; %>

<div class="container py-5">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
      <h2 class="mb-1 fw-bold">Games</h2>
    </div>

    <a href="/develop" class="btn btn-primary">Create New Game</a>
  </div>

  <% if (pageError) { %>
    <div class="alert alert-danger" role="alert">
      <%= pageError %>
    </div>
  <% } %>

  <% if (pageGames.length === 0) { %>
    <div class="card bg-black text-white border-secondary shadow">
      <div class="card-body p-4">
        <h5 class="card-title mb-2">No games yet</h5>
        <a href="/develop" class="btn btn-primary">Go To Develop</a>
      </div>
    </div>
  <% } else { %>
    <div class="row g-4">
      <% pageGames.forEach((game) => { %>
        <div class="col-sm-6 col-xl-4">
          <div class="card bg-black text-white border-secondary h-100 shadow">
            <img
              class="card-img-top"
              src="https://placehold.co/600x340/111111/FFFFFF?text=ZOMIUM+GAME"
              alt="<%= game.name %>"
            >

            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><%= game.name %></h5>
              <p class="card-text text-secondary flex-grow-1"><%= game.description %></p>
              <p class="card-text text-light mb-3">
                Made by <%= game.creator_username || (viewer ? viewer.username : "Guest") %>
              </p>
              <a href="#" class="btn btn-primary">Play</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include("partials/footer") %>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
 </body>
 </html>
