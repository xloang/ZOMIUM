<% const viewer = typeof currentUser !== "undefined" ? currentUser : null; %>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary">
  <div class="container">
    <a class="navbar-brand fw-bold text-light" href="<%= viewer ? '/my/home' : '/' %>">
      ZOMIUM
    </a>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarSupportedContent"
      aria-controls="navbarSupportedContent"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">
  <ul class="navbar-nav me-auto mb-2 mb-lg-0">
    
    <li class="nav-item">
      <a class="nav-link active text-light" href="<%= viewer ? '/my/home' : '/' %>">
        Home
      </a>
    </li>

    <li class="nav-item">
      <a class="nav-link active text-light" href="<%= viewer ? '/games' : '/' %>">
        Games
      </a>
    </li>
<li class="nav-item">
      <a class="nav-link active text-light" href="<%= viewer ? '/catalog' : '/' %>">
        Catalog
      </a>
    </li>
  </ul>
</div>

      <% if (viewer) { %>
        <div class="d-flex align-items-center gap-3 ms-auto">
          <span class="text-light fw-semibold"><%= viewer.username %></span>

          <form action="/logout" method="post" class="mb-0">
            <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
          </form>
        </div>
      <% } else { %>
        <div class="d-flex align-items-center gap-2 ms-auto">
          <a href="/register" class="btn btn-primary">Register</a>
          <a href="/login" class="btn btn-primary">Login</a>
        </div>
      <% } %>
    </div>
  </div>
</nav>
